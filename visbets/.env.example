# ─────────────────────────────────────────────────────────────────────────────
# VISBETS — Environment Variables
# Copy this file to .env and fill in all values before running the app.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ────────────────────────────────────────────────────────────────
# Create a new project at https://supabase.com and grab these from:
#   Project Settings → API → Project URL / anon key
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# ── Google OAuth ─────────────────────────────────────────────────────────────
# These are the OAuth 2.0 client IDs from Google Cloud Console.
# iOS client: Project → Credentials → iOS OAuth client
# Web client: Project → Credentials → Web application OAuth client
# iOS OAuth 2.0 client ID from Google Cloud Console → Credentials → iOS client
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=YOUR_IOS_CLIENT_ID.apps.googleusercontent.com

# Web OAuth 2.0 client ID from Google Cloud Console → Credentials → Web application
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=YOUR_WEB_CLIENT_ID.apps.googleusercontent.com

# ── RevenueCat ───────────────────────────────────────────────────────────────
# Get these from RevenueCat dashboard → Project → API Keys
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=

# ── Amplitude ────────────────────────────────────────────────────────────────
# Get from Amplitude → Settings → Projects → API Key
EXPO_PUBLIC_AMPLITUDE_API_KEY=

# ── Sentry ───────────────────────────────────────────────────────────────────
# Get from Sentry → Settings → Projects → visbets-mobile → Client Keys (DSN)
# If empty, crash reporting is disabled (safe for local dev).
EXPO_PUBLIC_SENTRY_DSN=

# ── Backend ──────────────────────────────────────────────────────────────────
# Local dev: http://localhost:3001
# Production: your Railway deploy URL (e.g. https://visbets-backend.up.railway.app)
EXPO_PUBLIC_API_BASE_URL=http://localhost:3001

# ── Data APIs (backend only — NEVER expose these to the client) ───────────────
# These live in /backend/.env, NOT here. Listed for documentation only.
# API_SPORTS_KEY=       → api-sports.io key
# ODDS_API_KEY=         → the-odds-api.com key

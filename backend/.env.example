PORT=3001
NODE_ENV=development

# Supabase — use the SERVICE ROLE key (not the anon key) for backend writes
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Data APIs
API_SPORTS_KEY=
ODDS_API_KEY=

# RevenueCat webhook secret (set in RevenueCat dashboard → Project → Integrations → Webhooks)
REVENUECAT_WEBHOOK_SECRET=

# Game hours window (ET, 24-hour). Controls analysis cache TTL (8 min vs 2 hr).
GAME_HOURS_START=12
GAME_HOURS_END=24

# CORS — comma-separated list of allowed origins (mobile apps use capacitor:// or exp://)
# Leave empty to allow all origins in development
ALLOWED_ORIGINS=

# Redis — Upstash Redis URL (redis://:<password>@<host>:<port>)
# Leave empty to disable Redis caching (local dev without Redis is fully supported)
REDIS_URL=

# Sentry error tracking (optional — leave empty to disable)
SENTRY_DSN=

# Log level (debug, info, warn, error). Defaults to 'info' in production, 'debug' in dev.
LOG_LEVEL=

# RevenueCat Secret API Key (NOT the public SDK key — find it under Project → API Keys → Secret)
# Used to verify entitlements server-side before writing subscription tier.
REVENUECAT_SECRET_KEY=

# Admin API key — protects /api/admin/* endpoints (backfill, odds refresh).
# Generate a secure value with: openssl rand -hex 32
# REQUIRED in production — server will return 503 on all admin routes if unset.
ADMIN_API_KEY=
